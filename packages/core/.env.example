# feathers-baas — environment variables
# Copy this file to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=3030
NODE_ENV=development

# Database (Postgres)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/feathers_baas
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/feathers_baas_test

# Auth
# Must be at least 32 characters
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Argon2 password hashing (OWASP recommended defaults)
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000

# Bootstrap admin (used by db:seed — optional)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# ─── Notifications (optional) ─────────────────────────────────────────────────
# Set REDIS_URL to enable the BullMQ-backed notification queue.
# Without it, auth emails are logged to console and never sent.
# REDIS_URL=redis://localhost:6379

# Public base URL included in verification/reset email links
# APP_URL=http://localhost:3030

# SMTP driver (nodemailer) — set SMTP_URL + SMTP_FROM_ADDRESS to enable
# SMTP_URL=smtp://user:pass@localhost:1025
# SMTP_FROM_NAME=feathers-baas
# SMTP_FROM_ADDRESS=no-reply@example.com

# Resend driver — set RESEND_API_KEY + RESEND_FROM_ADDRESS to enable
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_NAME=feathers-baas
# RESEND_FROM_ADDRESS=no-reply@yourdomain.com

# SendGrid driver — set SENDGRID_API_KEY + SENDGRID_FROM_ADDRESS to enable
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx
# SENDGRID_FROM_NAME=feathers-baas
# SENDGRID_FROM_ADDRESS=no-reply@yourdomain.com

# Brevo driver — set BREVO_API_KEY + BREVO_FROM_ADDRESS to enable
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxx
# BREVO_FROM_NAME=feathers-baas
# BREVO_FROM_ADDRESS=no-reply@yourdomain.com
