{
  "name": "@feathers-baas/core",
  "version": "0.2.0",
  "description": "Core Feathers.js v5 app factory for feathers-baas",
  "keywords": [
    "feathers",
    "feathersjs",
    "backend",
    "baas"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./exports": {
      "import": {
        "types": "./dist/exports.d.ts",
        "default": "./dist/exports.js"
      },
      "require": {
        "types": "./dist/exports.d.cts",
        "default": "./dist/exports.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "db:migrate": "node --import tsx/esm ./node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.ts",
    "db:rollback": "node --import tsx/esm ./node_modules/knex/bin/cli.js migrate:rollback --knexfile knexfile.ts",
    "db:seed": "node --import tsx/esm ./node_modules/knex/bin/cli.js seed:run --knexfile knexfile.ts",
    "db:reset": "node --import tsx/esm ./node_modules/knex/bin/cli.js migrate:rollback --all --knexfile knexfile.ts && pnpm db:migrate"
  },
  "dependencies": {
    "@feathers-baas/plugin-notifications": "workspace:*",
    "@feathersjs/authentication": "^5.0.30",
    "@feathersjs/authentication-local": "^5.0.30",
    "@feathersjs/authentication-oauth": "^5.0.30",
    "@feathersjs/errors": "^5.0.30",
    "@feathersjs/feathers": "^5.0.30",
    "@feathersjs/knex": "^5.0.30",
    "@feathersjs/koa": "^5.0.30",
    "@feathersjs/mongodb": "^5.0.44",
    "@feathersjs/typebox": "^5.0.30",
    "@sinclair/typebox": "^0.25.0",
    "argon2": "^0.41.0",
    "dotenv": "^16.4.0",
    "feathers-authentication-management": "^4.0.0",
    "feathers-hooks-common": "^8.2.1",
    "ioredis": "^5.3.2",
    "knex": "^3.1.0",
    "lru-cache": "^11.0.0",
    "pg": "^8.13.0",
    "pino": "^9.0.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0",
    "mongodb": "^6.0.0",
    "mysql2": "^3.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/pg": "^8.11.0",
    "bullmq": "^5.74.1",
    "pino-pretty": "*",
    "tsup": "*",
    "tsx": "^4.19.0",
    "typescript": "*",
    "vitest": "*"
  }
}
