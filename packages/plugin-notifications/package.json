{
  "name": "@feathers-baas/plugin-notifications",
  "version": "0.2.0",
  "description": "Notifications plugin for feathers-baas — BullMQ-backed email drivers (SMTP, Resend, SendGrid, Brevo)",
  "keywords": [
    "feathers",
    "feathersjs",
    "notifications",
    "email",
    "bullmq",
    "feathers-baas-plugin"
  ],
  "feathers-baas-plugin": true,
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@feathersjs/feathers": "^5.0.30",
    "@getbrevo/brevo": "^2.2.0",
    "@sendgrid/mail": "^8.1.0",
    "bullmq": "^5.12.0",
    "ejs": "^3.1.10",
    "ioredis": "^5.3.2",
    "nodemailer": "^6.9.14",
    "resend": "^3.5.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/nodemailer": "^6.4.15",
    "ioredis-mock": "^8.9.0",
    "tsup": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
