{
  "name": "@feathers-baas/plugin-notifications",
  "version": "0.0.1",
  "description": "Notifications plugin for feathers-baas — BullMQ-backed email drivers (SMTP, Resend)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@feathersjs/feathers": "^5.0.30",
    "@getbrevo/brevo": "^2.2.0",
    "@sendgrid/mail": "^8.1.0",
    "bullmq": "^5.12.0",
    "ejs": "^3.1.10",
    "ioredis": "^5.3.2",
    "nodemailer": "^6.9.14",
    "resend": "^3.5.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/nodemailer": "^6.4.15",
    "ioredis-mock": "^8.9.0",
    "tsup": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
