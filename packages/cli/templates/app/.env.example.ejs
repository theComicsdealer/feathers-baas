# ─── Required ──────────────────────────────────────────────────────────────────
<% if (database === 'postgresql') { -%>
DATABASE_URL=postgres://postgres:postgres@localhost:5432/<%- projectName.replace(/-/g, '_') %>
<% } else if (database === 'mysql') { -%>
MYSQL_URL=mysql://root:root@localhost:3306/<%- projectName.replace(/-/g, '_') %>
<% } else if (database === 'sqlite') { -%>
SQLITE_FILENAME=./data/<%- projectName %>.db
<% } else if (database === 'mongodb') { -%>
MONGODB_URL=mongodb://localhost:27017/<%- projectName.replace(/-/g, '_') %>
<% } -%>
JWT_SECRET=change-me-to-a-random-secret-that-is-at-least-32-chars

# ─── Optional ──────────────────────────────────────────────────────────────────
# PORT=3030
# HOST=0.0.0.0
# NODE_ENV=development
# CORS_ORIGINS=http://localhost:3000

# ─── Admin seed ────────────────────────────────────────────────────────────────
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=supersecret

# ─── Email notifications ───────────────────────────────────────────────────────
# Public base URL used in verification/reset email links
# APP_URL=http://localhost:3030

<% if (emailDriver === 'smtp') { -%>
SMTP_URL=smtp://user:pass@localhost:1025
SMTP_FROM_NAME=<%- projectName %>
SMTP_FROM_ADDRESS=no-reply@example.com
<% } else if (emailDriver === 'resend') { -%>
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_NAME=<%- projectName %>
RESEND_FROM_ADDRESS=no-reply@example.com
<% } else if (emailDriver === 'sendgrid') { -%>
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
SENDGRID_FROM_NAME=<%- projectName %>
SENDGRID_FROM_ADDRESS=no-reply@example.com
<% } else if (emailDriver === 'brevo') { -%>
BREVO_API_KEY=xkeysib-xxxxxxxxxxxx
BREVO_FROM_NAME=<%- projectName %>
BREVO_FROM_ADDRESS=no-reply@example.com
<% } else { -%>
# No email driver selected — auth emails are logged to console.
# Uncomment one of the blocks below to enable sending.

# SMTP (nodemailer):
# SMTP_URL=smtp://user:pass@localhost:1025
# SMTP_FROM_NAME=<%- projectName %>
# SMTP_FROM_ADDRESS=no-reply@example.com

# Resend:
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_NAME=<%- projectName %>
# RESEND_FROM_ADDRESS=no-reply@example.com

# SendGrid:
# SENDGRID_API_KEY=SG.xxxxxxxxxxxx
# SENDGRID_FROM_NAME=<%- projectName %>
# SENDGRID_FROM_ADDRESS=no-reply@example.com

# Brevo:
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxx
# BREVO_FROM_NAME=<%- projectName %>
# BREVO_FROM_ADDRESS=no-reply@example.com
<% } -%>

# Redis (enables BullMQ queue for email retries — optional)
# REDIS_URL=redis://localhost:6379

# ─── File storage ──────────────────────────────────────────────────────────────
<% if (storageDriver === 's3') { -%>
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# AWS_ENDPOINT=http://localhost:9000   # MinIO / LocalStack endpoint
# AWS_FORCE_PATH_STYLE=true            # Required for MinIO
<% } else if (storageDriver === 'gcs') { -%>
GCS_BUCKET=
# GCS_KEY_FILENAME=/path/to/service-account.json   # Omit to use Application Default Credentials
<% } else if (storageDriver === 'local') { -%>
# Local driver — files are stored on disk, no extra env vars needed.
# Switching to S3 or GCS later: add AWS_* or GCS_* vars and swap the driver in src/app.ts.
<% } else { -%>
# No file storage driver selected.
# S3 / MinIO:
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_ENDPOINT=http://localhost:9000
# AWS_FORCE_PATH_STYLE=true
#
# Google Cloud Storage:
# GCS_BUCKET=
# GCS_KEY_FILENAME=/path/to/service-account.json
<% } -%>
