{
  "name": "<%- projectName %>",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "migrate": "npx feathers-baas migrate",
    "rollback": "npx feathers-baas rollback",
    "seed": "npx feathers-baas seed"
  },
  "dependencies": {
    "@feathers-baas/core": "^<%- versions.core %>",
    "@feathers-baas/plugin-files": "^<%- versions.pluginFiles %>",
    "@feathers-baas/plugin-notifications": "^<%- versions.pluginNotifications %>",
    "@feathersjs/authentication": "^5.0.30",
    "@feathersjs/errors": "^5.0.30",
    "@feathersjs/feathers": "^5.0.30",
    "@feathersjs/typebox": "^5.0.30",
    "feathers-hooks-common": "^8.2.1",
    "lru-cache": "^11.0.0",
<% if (database === 'mongodb') { -%>
    "@feathersjs/mongodb": "^5.0.44",
    "mongodb": "^6.0.0",
<% } else { -%>
    "@feathersjs/knex": "^5.0.30",
    "knex": "^3.1.0",
<% } -%>
<% if (database === 'postgresql') { -%>
    "pg": "^8.13.0",
<% } else if (database === 'mysql') { -%>
    "mysql2": "^3.0.0",
<% } else if (database === 'sqlite') { -%>
    "better-sqlite3": "^11.0.0",
<% } -%>
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "feathers-baas": "^<%- versions.cli %>",
    "pino-pretty": "*",
    "tsup": "*",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "*"
  }
}
