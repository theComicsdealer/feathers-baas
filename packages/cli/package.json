{
  "name": "feathers-baas",
  "version": "0.7.0",
  "description": "CLI scaffolder for production-ready Feathers.js v5 backends",
  "keywords": [
    "feathers",
    "feathersjs",
    "cli",
    "scaffold",
    "baas"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "feathers-baas": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "clipanion": "^3.2.0",
    "ejs": "^3.1.10",
    "ora": "^8.0.0",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "tsup": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
